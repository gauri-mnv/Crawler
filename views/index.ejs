<!DOCTYPE html>
<html>
<head>
    <title>Crawler Results</title>
<style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; padding: 40px; background: #f0f2f5; }
        .container { max-width: 1200px; margin: auto; background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        .header { text-align: center; border-bottom: 2px solid #eee; margin-bottom: 20px; padding-bottom: 10px; }
        
        /* Form styling */
        form { display: flex; gap: 10px; justify-content: center; margin-bottom: 30px; }
        input { flex: 1; padding: 12px; border: 1px solid #ddd; border-radius: 6px; font-size: 16px; max-width: 600px; }
        button { padding: 12px 25px; background: #28a745; color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; transition: 0.3s; }
        button:hover { background: #218838; }

        /* Stats Section using Flexbox */
        .stats-container { 
            display: flex; 
           
            justify-content: space-between; 
            gap: 20px; 
            margin: 20px 0; 
        }
        .stats-grid { display: flex; 
            flex-direction:row; gap: 20px; }

        .stat-card { 
            flex: 1; /* Teeno cards barabar space lenge */
            background: #e9ecef; 
            padding: 20px; 
            border-radius: 8px; 
            text-align: center; 
            border-bottom: 4px solid #007bff;
        }
        .stat-card h2 { margin: 0; color: #007bff; font-size: 28px; }
        .stat-card p { margin: 5px 0 0; font-weight: bold; color: #555; }

        /* Result Columns using Flexbox */
        .result-box { 
            display: flex; 
            flex-wrap: nowrap; /* Mobile par wrap karne ke liye wrap use kar sakte hain */
            gap: 20px; 
            margin-top: 20px;
        }
        .column { 
            flex: 1; /* Teeno column barabar width ke honge */
            height: 500px; 
            overflow-y: auto; 
            border: 1px solid #eee; 
            padding: 15px; 
            border-radius: 8px; 
            background: #fafafa; 
        }
        
        h3 { color: #333; border-bottom: 1px solid #ddd; padding-bottom: 10px; font-size: 18px; display: flex; align-items: center; gap: 8px; }
        ul { list-style: none; padding: 0; }
        li { font-size: 14px; margin-bottom: 12px; color: #555; line-height: 1.4; border-bottom: 1px solid #f0f0f0; padding-bottom: 5px; }
        a { color: #007bff; text-decoration: none; word-break: break-all; }
        a:hover { text-decoration: underline; }

        /* Custom Scrollbar for better look */
        .column::-webkit-scrollbar { width: 6px; }
        .column::-webkit-scrollbar-thumb { background: #ccc; border-radius: 10px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🕵️‍♀️ Basic NestJS Crawler</h1>
        </div>

        <form action="/scrape/Headlines" method="POST">
            <input type="text" name="target" placeholder="Enter URL (e.g. https://google.com)" required value="<%= typeof url !== 'undefined' ? url : '' %>">
            <button type="submit">Start Crawling</button>
        </form>

        <% if (typeof stats !== 'undefined') { %>
            <div class="stats-grid">
                <div class="stat-card">
                    <h2><%= stats.totalHeadlines %></h2>
                    <p>Headlines Found</p>
                </div>
                <div class="stat-card">
                    <h2><%= stats.totalLinksFound %></h2>
                    <p>Links Found</p>
                </div>
                 <div class="stat-card">
                    <h2><%= stats.totalParagraphs %></h2>
                    <p>Paragraphs Found</p>
                </div>
            </div>

            <div class="result-box">
                <div class="column">
                    <h3>📄 Headlines</h3>
                    <ul>
                        <% headlines.forEach(function(h) { %>
                            <li><strong>•</strong> <%= h %></li>
                        <% }); %>
                    </ul>
                </div>

                <div class="column">
                    <h3>🔗 Links (Next Page)</h3>
                    <ul>
                        <% nextPageOptions.forEach(function(link) { %>
                            <li><a href="<%= link %>" target="_blank"><%= link %></a></li>
                        <% }); %>
                    </ul>
                </div>

                    <div class="column">
                            <h3>📄 Paragraphs</h3>
                            <ul>
                                <% if (typeof paragraphs !== 'undefined') { %>
                                    <% paragraphs.forEach(function(p) { %>
                                        <li><strong>•</strong> <%= p %></li>
                                    <% }); %>
                                <% } %>
                            </ul>
                        </div>
            
            </div>
        <% } %>
    </div>
</body>
</html>